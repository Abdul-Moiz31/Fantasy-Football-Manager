# ── API ───────────────────────────────────────────────────────────────────────
# In development, leave this unset — Vite proxies /api to localhost:5000
# In production, leave unset too — the server serves both API and client
# VITE_API_URL=http://localhost:5000/api

# ── App meta ─────────────────────────────────────────────────────────────────
VITE_APP_NAME="Fantasy Football Manager"
VITE_APP_VERSION=1.0.0

# ── Dev server port ───────────────────────────────────────────────────────────
VITE_PORT=3000
