# ── Database ──────────────────────────────────────────────────────────────────
# MySQL connection string
DATABASE_URL="mysql://username:password@localhost:3306/fantasy_football_db"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production (Render), set this to your deployed URL, e.g.:
# CLIENT_URL=https://fantasy-football-manager.onrender.com
CLIENT_URL=http://localhost:3000
